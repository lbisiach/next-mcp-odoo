# Odoo connection
ODOO_URL=http://localhost:8069
ODOO_DB=your_database

# Authentication — use one method:
# Option A: API key (required for JSON-2)
ODOO_API_KEY=your-api-key-here

# Option B: username + password (XML-RPC only)
# ODOO_USER=admin
# ODOO_PASSWORD=admin

# Protocol: xmlrpc (default, Odoo 14-19) or json2 (Odoo 19+, no extra module needed)
ODOO_API_PROTOCOL=json2

# Execute level: safe (read-only) | business (default) | admin (system models)
ODOO_EXECUTE_LEVEL=business

# Optional
# ODOO_MCP_LOG_LEVEL=INFO
# ODOO_MCP_DEFAULT_LIMIT=10
# ODOO_MCP_MAX_LIMIT=100
# ODOO_LOCALE=en_US
